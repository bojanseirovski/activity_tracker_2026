POSTGRES_USER=masiboard
POSTGRES_PASSWORD=masiboard
POSTGRES_DB=masiboard
DATABASE_URL=postgresql://masiboard:masiboard@localhost:5432/masiboard
JWT_SECRET=changeme_jwt_secret
CORS_ORIGIN=http://localhost:3001
PORT=3000
# Email provider: 'mailersend' or 'smtp'
EMAIL_PROVIDER=mailersend

# MailerSend (used when EMAIL_PROVIDER=mailersend)
MAILERSEND_API_KEY=your_key_here
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com

# Google SMTP (used when EMAIL_PROVIDER=smtp)
# SMTP_PASS must be a Google App Password (not your account password)
# Requires 2FA enabled: https://myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASS=your_google_app_password
SMTP_FROM=you@gmail.com
FRONTEND_URL=http://localhost:3001

A_ACCESS_KEY_ID=
A_SECRET_ACCESS_KEY=
A_REGION=
A_S3_BUCKET=